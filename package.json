{
  "name": "PetCare",
  "version": "1.0.2",
  "description": "PetCare desktop application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-packager": "^17.1.2",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.petcare.app",
    "productName": "PetCare",
    "files": [
      "**/*",
      "!pets.db"
    ],
    "asarUnpack": [
      "node_modules/sqlite3/**/*"
    ],
    "publish": {
      "provider": "github"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "build/icon.icon"
    },
    "win": {
      "target": "nsis"
    }
  }
}
